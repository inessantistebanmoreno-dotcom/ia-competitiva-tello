# =============================================================
# .env.example — Renombrar a ".env" y rellenar con tus valores
# NUNCA subir el .env real al repositorio
# =============================================================

# API de Anthropic (Claude Vision) — opcional
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXX

# API de Mistral (Pixtral Vision) — gratuito, disponible en España
# Obtener en: https://console.mistral.ai
MISTRAL_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PostgreSQL / Supabase
DATABASE_URL=postgresql://usuario:contraseña@host:5432/inteligencia_competitiva

# Email (SMTP Office 365 corporativo)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=agente-etiquetado@tello.es
SMTP_PASSWORD=contraseña_corporativa
EMAIL_FROM=agente-etiquetado@tello.es
EMAIL_TO=etiquetado@tello.es,producto@tello.es

# SendGrid (para envío de emails desde la nube — GitHub Actions)
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
